# --- LLM-диспетчер: любой OpenAI-совместимый провайдер ---

# Ключ API провайдера (обязательно)
MCC_API_KEY=

# Эндпоинт. По умолчанию — Cloud.ru Foundation Models.
#   Cloud.ru:   https://foundation-models.api.cloud.ru/v1
#   OpenAI:     https://api.openai.com/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   локально:   http://host.docker.internal:11434/v1  (Ollama), :1234/v1 (LM Studio)
MCC_BASE_URL=https://foundation-models.api.cloud.ru/v1

# ID модели у провайдера (должна поддерживать function calling / tools).
#   Cloud.ru: deepseek-ai/DeepSeek-V3, Qwen/Qwen2.5-72B-Instruct
#   OpenAI:   gpt-4o
MCC_MODEL=deepseek-ai/DeepSeek-V3

# Прочее (необязательно)
MCC_MAX_TOKENS=4096
MCC_TEMPERATURE=0.3
# MCC_STREAM=1     # 0 — если провайдер не поддерживает stream вместе с tools
# Лимит шагов на директиву: 0 = без лимита (агент работает до завершения)
MCC_MAX_TOOL_ITERATIONS=0
# Сколько последних снимков телеметрии держать в полном виде (старые сжимаются)
MCC_KEEP_RECENT_TOOL_RESULTS=24

# --- Мост к игре ---

# Путь к установленной KSP2 (для сборки мода)
KSP2_DIR=C:\Games\Kerbal Space Program 2

# Где бэкенду искать игру (host.docker.internal = игра на этой же машине)
KSP_BRIDGE_HOST=host.docker.internal
KSP_BRIDGE_PORT=8766
